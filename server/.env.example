# WeBook Self-Hosted Proxy Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your OpenRouter API key (from https://openrouter.ai/keys)
# OPTIONAL: If not provided, classification will fall back to local keyword matching.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use (optional — e.g. openai/gpt-4o-mini, anthropic/claude-3.5-haiku, etc. Default is google/gemini-2.5-flash)
MODEL_NAME=openai/gpt-4o-mini

# Port (default is 3000)
PORT=3000

# Optional: HTTP/HTTPS proxy to route scraping traffic (e.g. http://username:password@proxyip:port)
SCRAPING_PROXY=
